# URL of the Nazim web app to load in the desktop window.
# For production use your deployed app (e.g. https://app.nazim.cloud).
# For local development use your frontend dev server (e.g. http://localhost:5173).
NAZIM_APP_URL=https://app.nazim.cloud

# Optional: base URL for API/config if the desktop app ever needs to call the backend directly.
# NAZIM_API_URL=https://api.nazim.cloud
