{
  "name": "nazim-desktop",
  "version": "1.0.0",
  "description": "Electron wrapper that loads the Nazim web app from a URL",
  "author": "Nazim",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-rebuild -f -w better-sqlite3-multiple-ciphers || true",
    "build:renderer": "cd ../frontend && npm run build -- --base=./ && node ../desktop/scripts/copy-renderer-dist.js",
    "dist": "npm run build:renderer && node scripts/run-electron-builder.js",
    "dist:win": "npm run build:renderer && node scripts/run-electron-builder.js --win",
    "dist:win:dir": "npm run build:renderer && node scripts/run-electron-builder.js --win --dir"
  },
  "dependencies": {
    "better-sqlite3-multiple-ciphers": "^11.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.nazim.desktop",
    "productName": "Nazim",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "error.html",
      "src/**/*",
      "dist-renderer/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3-multiple-ciphers/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
